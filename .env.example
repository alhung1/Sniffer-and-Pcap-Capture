# Flask runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
FLASK_SECRET_KEY=change-me-in-production

# OpenWrt SSH connection
OPENWRT_HOST=192.168.1.1
OPENWRT_USER=root
# OPENWRT_PASSWORD=
# SSH_KEY_PATH=C:\Users\your-user\.ssh\id_rsa
SSH_PORT=22

# Local application behaviour
SNIFFER_DOWNLOADS=
LOG_LEVEL=INFO
# LOG_FILE=C:\Users\your-user\Sniffer and Pcap Capture\wifi_sniffer.log
APP_REMOTE_PREFIX=wifi_sniffer_capture

# Cache and monitoring
CONNECTION_CACHE_TTL=10
INTERFACE_CACHE_TTL=300
STATUS_UPDATE_INTERVAL=3
MONITOR_INTERVAL=5
MONITOR_ERROR_THRESHOLD=3
SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=30
